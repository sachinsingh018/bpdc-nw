# Generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=
NEXTAUTH_SECRET=

# Site URL (used for API calls, OAuth callbacks, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
APP_URL=http://localhost:3000

# Database (Neon Postgres)
POSTGRES_URL=
DATABASE_URL=

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# xAI API Key for chat/image models (https://console.x.ai/)
XAI_API_KEY=

# Groq API Key for reasoning models (https://console.groq.com/keys)
GROQ_API_KEY=

# OpenAI API Key for CV curator, transcription, interview responses (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Google Gemini API Key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Perplexity API Key (https://docs.perplexity.ai/)
PERPLEXITY_API_KEY=

# Resend for transactional emails (https://resend.com/)
RESEND_API_KEY=
RESEND_FROM=noreply@yourdomain.com

# AWS S3 for file uploads (resumes, images, company logos)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET_NAME=

# Vercel Blob Storage (https://vercel.com/docs/storage/vercel-blob)
BLOB_READ_WRITE_TOKEN=

# Firebase (for real-time features) (https://console.firebase.google.com/)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Proxycurl for LinkedIn data import (https://nubela.co/proxycurl/)
PROXYCURL_API_KEY=

# JSearch API for job fetching (https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch)
JSEARCH_API_KEY=

# Mailchimp for newsletter subscriptions
MAILCHIMP_API_KEY=
